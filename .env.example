# ============================================================
# GhostMarket — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- LLM APIs ---
GROQ_API_KEY=gsk_your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
NIM_API_KEY=your_nim_key_here

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Buffer ---
BUFFER_ACCESS_TOKEN=your_buffer_access_token_here
BUFFER_PROFILE_ID_INSTAGRAM=your_ig_profile_id
BUFFER_PROFILE_ID_TIKTOK=your_tiktok_profile_id
BUFFER_PROFILE_ID_FACEBOOK=your_fb_profile_id

# --- Replicate (image gen) ---
REPLICATE_API_TOKEN=your_replicate_token_here

# --- Reddit (no API key needed — uses public .json feeds) ---
REDDIT_USER_AGENT=ghostmarket:v1.0

# --- Vercel (landing page deploy) ---
VERCEL_TOKEN=your_vercel_token_here
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_PROJECT_ID=your_vercel_project_id

# --- Two-Machine Architecture (ROG GPU Worker) ---
# Set ROG_ENABLED=true on main PC after running scripts/setup-rog.sh on ROG
ROG_ENABLED=false
# Local IP of the ASUS ROG laptop (find with: hostname -I on ROG)
ROG_HOST=192.168.1.100
ROG_PORT=5555
ROG_SECRET=change_me
# Callback URL so ROG can push results back to this machine's orchestrator
ORCHESTRATOR_CALLBACK_URL=http://192.168.1.101:4000/callback

# --- Local Model (set to true after first fine-tune) ---
USE_LOCAL_MODEL=false

# --- Anthropic (for Claude Code self-improvement on ROG) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Database ---
GHOSTMARKET_DB=/data/ghostmarket.db

# --- System ---
NODE_ENV=production
LOG_LEVEL=info
