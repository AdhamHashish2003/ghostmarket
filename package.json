{
  "name": "ghostmarket",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:orchestrator": "tsc -p tsconfig.json",
    "build:builder": "tsc -p tsconfig.json",
    "build:deployer": "tsc -p tsconfig.json",
    "build:tracker": "tsc -p tsconfig.json",
    "build:telegram": "tsc -p tsconfig.json",
    "dev:orchestrator": "tsx src/orchestrator/index.ts",
    "dev:telegram": "tsx src/telegram/index.ts",
    "dev:builder": "tsx src/agents/builder/index.ts",
    "dev:deployer": "tsx src/agents/deployer/index.ts",
    "dev:tracker": "tsx src/agents/tracker/index.ts",
    "db:init": "sqlite3 data/ghostmarket.db < src/db/schema.sql"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "groq-sdk": "^0.9.0",
    "node-telegram-bot-api": "^0.66.0",
    "node-cron": "^3.0.3",
    "express": "^4.21.0",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/node-cron": "^3.0.11",
    "@types/express": "^5.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0"
  }
}
