{
  "name": "ghostmarket",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:scrapers": "npx tsx packages/scrapers/src/index.ts",
    "dev:scoring": "npx tsx packages/scoring/src/index.ts",
    "dev:dashboard": "cd packages/dashboard && npx next dev -p 3005",
    "dev": "concurrently \"npm run dev:scrapers\" \"npm run dev:scoring\" \"npm run dev:dashboard\"",
    "dev:all": "concurrently \"npm run dev:scrapers\" \"npm run dev:scoring\" \"npm run dev:dashboard\"",
    "build": "npm run build --workspaces",
    "db:migrate": "cd packages/shared && npx tsx src/db/migrate.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "setup": "npm install && npm run docker:up && sleep 3 && npm run db:migrate"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
